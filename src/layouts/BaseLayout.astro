---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "@components/Header.astro";
import PageTransition from "@components/PageTransition.astro";

interface Props {
  pageTitle?: string;
  description?: string;
  title?: string;
  srOnlyTitle?: boolean;
  subtitle?: string;
  subtitleCount?: number;
  lang?: string;
  isCenteredContent?: boolean;
}

const {
  pageTitle = "Thibaut LEFRANCOIS - portfolio",
  description = "Portfolio of Thibaut LEFRANCOIS, full-stack and creative web developer.",
  title,
  srOnlyTitle = true,
  subtitle,
  subtitleCount,
  lang = "en",
  isCenteredContent = true,
} = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@100,200,300,400,500,700,800,900&f[]=satoshi@100,200,300,400,500,700,800,900&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Schoolbell&display=swap"
    />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Thibaut LEFRANCOIS — Blog"
      href="/rss.xml"
    />
    <title>{pageTitle}</title>
    <slot name="head" />
    <ClientRouter />
  </head>

  <body class="flex min-h-dvh flex-col">
    <a
      href="#main-content"
      class="focus:bg-sage-1 focus:text-sage-12 sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:rounded focus:px-4 focus:py-2 focus:outline-2 focus:outline-offset-2 focus:outline-current"
    >
      Skip to content
    </a>
    <PageTransition />
    <Header />
    <main
      id="main-content"
      class:list={[
        "flex flex-1 flex-col px-6 py-6 md:px-10 md:py-10 lg:px-16",
        isCenteredContent && "lg:mx-auto",
      ]}
    >
      {
        title && !srOnlyTitle && (
          <div class="flex flex-col pb-6 md:pb-10">
            <h1
              class:list={[
                "text-3xl font-bold md:text-4xl",
                srOnlyTitle && "sr-only",
              ]}
            >
              {title}
            </h1>
            {subtitle && (
              <h2 class="text-xl font-semibold md:text-2xl">
                {subtitle}
                {subtitleCount !== undefined && (
                  <sub class="align-sub font-sans text-base opacity-50">
                    ({subtitleCount})
                  </sub>
                )}
              </h2>
            )}
          </div>
        )
      }
      <slot />
    </main>
    <footer
      class="text-sage-11 flex items-center justify-between px-6 py-6 text-xs md:px-10 lg:px-16"
    >
      <p>&copy; {new Date().getFullYear()} Thibaut LEFRANCOIS</p>
      <a href="/legal-notice" class="hover:text-sage-12 transition-colors"
        >Legal notice</a
      >
    </footer>
  </body>
</html>
