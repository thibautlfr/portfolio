---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Header from "@components/Header.astro";
import PageTransition from "@components/PageTransition.astro";

interface Props {
  pageTitle?: string;
  description?: string;
  title?: string;
  srOnlyTitle?: boolean;
  subtitle?: string;
  subtitleCount?: number;
}

const {
  pageTitle = "Thibaut LEFRANCOIS - portfolio",
  description = "Portfolio de Thibaut LEFRANCOIS, développeur web full-stack.",
  title,
  srOnlyTitle = true,
  subtitle,
  subtitleCount,
} = Astro.props;
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>

  <body class="flex min-h-dvh w-dvw flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-100 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-black focus:outline-2 focus:outline-offset-2 focus:outline-current"
    >
      Aller au contenu
    </a>
    <PageTransition />
    <Header />
    <main
      id="main-content"
      class="flex flex-1 flex-col px-6 py-6 md:px-10 md:py-10 lg:mx-auto lg:px-16"
    >
      {
        title && !srOnlyTitle && (
          <div class="flex flex-col pb-6 md:pb-10">
            <h1
              class:list={[
                "text-3xl font-bold md:text-4xl",
                srOnlyTitle && "sr-only",
              ]}
            >
              {title}
            </h1>
            {subtitle && (
              <h2 class="text-xl font-semibold md:text-2xl">
                {subtitle}
                {subtitleCount !== undefined && (
                  <sub class="align-sub font-sans text-base opacity-50">
                    ({subtitleCount})
                  </sub>
                )}
              </h2>
            )}
          </div>
        )
      }
      <slot />
    </main>
    <footer class="px-6 py-6 text-xs text-neutral-500 md:px-10 lg:px-16">
      <p>&copy; {new Date().getFullYear()} Thibaut LEFRANCOIS</p>
    </footer>
  </body>
</html>
