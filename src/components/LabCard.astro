---
import Link from "@components/icons/Link.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  id: string;
  title: string;
  description: string;
  date: number;
  tags: string[];
  demo: string;
  repository?: string;
  image?: ImageMetadata;
}

const { id, title, description, date, tags, demo, repository, image } =
  Astro.props;
const expId = `EXP ${String(Number(id) + 1).padStart(3, "0")}`;
---

<a
  href={demo}
  class="lab-card relative flex flex-1 cursor-pointer items-center justify-between border-b py-6 md:py-10"
  target="_blank"
  rel="noopener noreferrer"
>
  <div class="flex items-center gap-10">
    <div class="text-sm md:text-base">{expId}</div>
    <div class="hidden md:block">{date}</div>
    <div
      class="lab-card-title overflow-hidden text-xl whitespace-nowrap md:text-2xl"
    >
      {title}
    </div>
  </div>

  <div class="hidden md:block">
    {tags.map((tag) => <span class="pl-2 first:pl-0">{tag}</span>)}
  </div>

  {
    image && (
      <Image
        src={image}
        alt={`${title} project cover`}
        aria-hidden="true"
        class="image-hover z-1000 aspect-video w-1/4 rounded-md object-cover shadow-2xl"
        quality={80}
      />
    )
  }
</a>

<script>
  import { gsap } from "gsap";
  import { ScrambleTextPlugin } from "gsap/ScrambleTextPlugin";

  gsap.registerPlugin(ScrambleTextPlugin);

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  document.querySelectorAll<HTMLElement>(".lab-card").forEach((card) => {
    const titleEl = card.querySelector<HTMLElement>(".lab-card-title");
    const image = card.querySelector<HTMLElement>(".image-hover");
    if (!titleEl || !image) return;

    const originalText = titleEl.textContent ?? "";
    let tween: gsap.core.Tween | null = null;
    let tweenImage: gsap.core.Tween | null = null;

    gsap.set(image, {
      position: "fixed",
      top: 0,
      left: 0,
      pointerEvents: "none",
      opacity: 0,
      willChange: "transform, opacity",
    });

    card.addEventListener("mouseenter", (e) => {
      if (prefersReduced) return;
      tween?.kill();
      titleEl.style.width = `${titleEl.offsetWidth}px`;
      tween = gsap.to(titleEl, {
        scrambleText: {
          text: originalText,
          chars: "!@#$%^&*()",
          tweenLength: false,
        },
        onComplete: () => {
          titleEl.style.width = "";
        },
      });

      gsap.killTweensOf(image);
      gsap.set(image, { x: e.clientX, y: e.clientY });
      tweenImage = gsap.to(image, {
        opacity: 1,
        scale: 1,
        duration: 0.2,
        ease: "power2.out",
      });
    });

    card.addEventListener("mousemove", (e) => {
      if (prefersReduced || !tweenImage) return;
      gsap.to(image, {
        x: e.clientX,
        y: e.clientY,
        duration: 0.1,
        ease: "none",
      });
    });

    card.addEventListener("mouseleave", () => {
      tween?.kill();
      gsap.set(titleEl, { scrambleText: originalText });
      titleEl.style.width = "";

      gsap.to(image, {
        opacity: 0,
        scale: 0.8,
        duration: 0.2,
        ease: "power2.in",
      });
    });
  });
</script>
