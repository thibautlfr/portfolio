---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  id: number;
  title: string;
  date: Date;
  tags: string[];
  demo: string;
  repository?: string;
  image?: ImageMetadata;
}

const { id, title, date, tags, demo, repository, image } = Astro.props;
const expId = `EXP ${String(id + 1).padStart(3, "0")}`;
---

<div
  class="lab-card border-sage-6 relative flex flex-1 cursor-pointer items-center justify-between border-b py-6 md:py-10"
>
  <a
    href={demo}
    class="absolute inset-0 z-0"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="sr-only">{title} (s'ouvre dans un nouvel onglet)</span>
  </a>

  <div class="flex items-center gap-10">
    <div class="text-sm md:text-base">{expId}</div>
    <div class="hidden md:block">{date.getFullYear()}</div>
    <div
      class="lab-card-title overflow-hidden text-xl whitespace-nowrap md:text-2xl"
    >
      {title}
    </div>
  </div>

  <div class="flex items-center gap-3">
    <div class="hidden items-center gap-2 md:flex">
      {
        tags.map((tag) => (
          <span class="bg-sage-3 text-sage-11 rounded-full px-2.5 py-0.5 text-xs">
            {tag}
          </span>
        ))
      }
    </div>

    {
      repository && (
        <a
          href={repository}
          class="text-sage-11 hover:text-sage-12 relative z-10 p-1.5 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Repository GitHub de ${title}`}
        >
          <span class="sr-only">(s'ouvre dans un nouvel onglet)</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
          </svg>
        </a>
      )
    }
  </div>

  {
    image && (
      <Image
        src={image}
        alt={`Image for ${title}`}
        aria-hidden="true"
        class="image-hover z-1000 aspect-video w-1/4 rounded-md object-cover shadow-2xl"
        quality={80}
      />
    )
  }
  <div
    class="lab-card-border-line bg-sage-12 absolute bottom-0 left-0 h-px w-full origin-left"
  >
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrambleTextPlugin } from "gsap/ScrambleTextPlugin";

  gsap.registerPlugin(ScrambleTextPlugin);

  document.addEventListener("astro:page-load", () => {
    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    document.querySelectorAll<HTMLElement>(".lab-card").forEach((card) => {
      const titleEl = card.querySelector<HTMLElement>(".lab-card-title");
      const image = card.querySelector<HTMLElement>(".image-hover");
      const borderLine = card.querySelector<HTMLElement>(
        ".lab-card-border-line",
      );
      if (!titleEl) return;

      if (borderLine) {
        gsap.set(borderLine, { scaleX: 0 });
      }

      const originalText = titleEl.textContent ?? "";
      let tween: gsap.core.Tween | null = null;

      if (image) {
        gsap.set(image, {
          position: "fixed",
          top: 0,
          left: 0,
          pointerEvents: "none",
          opacity: 0,
          scale: 0.8,
          willChange: "transform, opacity",
        });
      }

      card.addEventListener("mouseenter", (e) => {
        if (prefersReduced) return;
        tween?.kill();
        titleEl.style.width = `${titleEl.offsetWidth}px`;
        tween = gsap.to(titleEl, {
          scrambleText: {
            text: originalText,
            chars: "!@#$%^&*()",
            tweenLength: false,
          },
          onComplete: () => {
            titleEl.style.width = "";
          },
        });

        if (borderLine) {
          gsap.killTweensOf(borderLine);
          gsap.to(borderLine, {
            scaleX: 1,
            duration: 0.5,
            ease: "power2.out",
          });
        }

        if (image) {
          gsap.killTweensOf(image);
          gsap.set(image, { x: e.clientX, y: e.clientY });
          gsap.to(image, {
            opacity: 1,
            scale: 1,
            duration: 0.2,
            ease: "power2.out",
          });
        }
      });

      card.addEventListener("mousemove", (e) => {
        if (prefersReduced || !image) return;
        gsap.to(image, {
          x: e.clientX,
          y: e.clientY,
          duration: 0.1,
          ease: "none",
        });
      });

      card.addEventListener("mouseleave", () => {
        tween?.kill();
        titleEl.textContent = originalText;
        titleEl.style.width = "";

        if (borderLine) {
          gsap.killTweensOf(borderLine);
          gsap.to(borderLine, {
            scaleX: 0,
            duration: 0.3,
            ease: "power2.in",
          });
        }

        if (image) {
          gsap.to(image, {
            opacity: 0,
            scale: 0.8,
            duration: 0.2,
            ease: "power2.in",
          });
        }
      });
    });
  });
</script>
