---
import Link from "@components/icons/Link.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  date: number;
  tags: string[];
  demo?: string;
  repository?: string;
}

const { id, title, description, date, tags, demo, repository } = Astro.props;
const expId = `EXP ${String(Number(id) + 1).padStart(3, "0")}`;
---

<article
  class="lab-card relative flex flex-1 items-center justify-between border-b py-6 md:py-10"
>
  <div class="flex w-1/2 items-center gap-10">
    <div class="text-sm md:text-base">{expId}</div>
    <div class="hidden md:block">{date}</div>
    <div
      class="lab-card-title overflow-hidden text-xl whitespace-nowrap md:text-2xl"
    >
      {title}
    </div>
  </div>
  <div class="hidden md:block">
    {tags.map((tag) => <span class="pl-2 first:pl-0">{tag}</span>)}
  </div>
  <div>button</div>
</article>

<script>
  import { gsap } from "gsap";
  import { ScrambleTextPlugin } from "gsap/ScrambleTextPlugin";

  gsap.registerPlugin(ScrambleTextPlugin);

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  document.querySelectorAll<HTMLElement>(".lab-card").forEach((card) => {
    const titleEl = card.querySelector<HTMLElement>(".lab-card-title");
    if (!titleEl) return;

    const originalText = titleEl.textContent ?? "";
    let tween: gsap.core.Tween | null = null;

    card.addEventListener("mouseenter", () => {
      if (prefersReduced) return;
      tween?.kill();
      titleEl.style.width = `${titleEl.offsetWidth}px`;
      tween = gsap.to(titleEl, {
        scrambleText: {
          text: originalText,
          chars: "!@#$%^&*()",
          tweenLength: false,
        },
        onComplete: () => {
          titleEl.style.width = "";
        },
      });
    });

    card.addEventListener("mouseleave", () => {
      tween?.kill();
      gsap.set(titleEl, { scrambleText: originalText });
      titleEl.style.width = "";
    });
  });
</script>
