---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import GitHub from "@components/icons/GitHub.astro";

interface Props {
  id: number;
  title: string;
  date: Date;
  tags: string[];
  demo: string;
  repository?: string;
  image?: ImageMetadata;
}

const { id, title, date, tags, demo, repository, image } = Astro.props;
const expId = `EXP ${String(id + 1).padStart(3, "0")}`;
---

<div
  class="lab-card border-sage-6 relative flex flex-1 cursor-pointer items-center justify-between border-b py-6 md:py-10 focus-within:outline focus-within:outline-2 focus-within:outline-current focus-within:outline-offset-2"
>
  <a
    href={demo}
    class="absolute inset-0 z-0 outline-none"
    target="_blank"
    rel="noopener noreferrer"
  >
    <span class="sr-only">{title} (opens in new tab)</span>
  </a>

  <div class="flex items-center gap-10">
    <div class="text-sm md:text-base">{expId}</div>
    <div class="hidden md:block">{date.getFullYear()}</div>
    <div
      class="lab-card-title overflow-hidden text-xl whitespace-nowrap md:text-2xl"
    >
      {title}
    </div>
  </div>

  <div class="flex items-center gap-3">
    <div class="hidden items-center gap-2 md:flex">
      {
        tags.map((tag) => (
          <span class="bg-sage-3 text-sage-11 rounded-full px-2.5 py-0.5 text-xs">
            {tag}
          </span>
        ))
      }
    </div>

    {
      repository && (
        <a
          href={repository}
          class="text-sage-11 hover:text-sage-12 relative z-10 p-1.5 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} GitHub repository`}
        >
          <span class="sr-only">(opens in new tab)</span>
          <GitHub />
        </a>
      )
    }
  </div>

  {
    image && (
      <Image
        src={image}
        alt={`Image for ${title}`}
        aria-hidden="true"
        class="image-hover z-1000 aspect-video w-1/4 rounded-md object-cover shadow-2xl"
        quality={80}
      />
    )
  }
  <div
    class="lab-card-border-line bg-sage-12 absolute bottom-0 left-0 h-px w-full origin-left"
  >
  </div>
</div>

<script>
  import { gsap } from "gsap";
  import { ScrambleTextPlugin } from "gsap/ScrambleTextPlugin";

  gsap.registerPlugin(ScrambleTextPlugin);

  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  let abortController: AbortController | null = null;

  document.addEventListener("astro:before-swap", () => {
    abortController?.abort();
  });

  document.addEventListener("astro:page-load", () => {
    abortController?.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    document.querySelectorAll<HTMLElement>(".lab-card").forEach((card) => {
      const titleEl = card.querySelector<HTMLElement>(".lab-card-title");
      const image = card.querySelector<HTMLElement>(".image-hover");
      const borderLine = card.querySelector<HTMLElement>(
        ".lab-card-border-line",
      );
      if (!titleEl) return;

      if (borderLine) {
        gsap.set(borderLine, { scaleX: 0 });
      }

      const originalText = titleEl.textContent ?? "";
      let tween: gsap.core.Tween | null = null;

      if (image) {
        gsap.set(image, {
          position: "fixed",
          top: 0,
          left: 0,
          pointerEvents: "none",
          opacity: 0,
          scale: 0.8,
          willChange: "transform, opacity",
        });
      }

      const handleEnter = () => {
        if (prefersReduced) return;
        tween?.kill();
        titleEl.style.width = `${titleEl.offsetWidth}px`;
        tween = gsap.to(titleEl, {
          scrambleText: {
            text: originalText,
            chars: "!@#$%^&*()",
            tweenLength: false,
          },
          onComplete: () => {
            titleEl.style.width = "";
          },
        });

        if (borderLine) {
          gsap.killTweensOf(borderLine);
          gsap.to(borderLine, {
            scaleX: 1,
            duration: 0.5,
            ease: "power2.out",
          });
        }
      };

      const handleLeave = () => {
        tween?.kill();
        titleEl.textContent = originalText;
        titleEl.style.width = "";

        if (borderLine) {
          gsap.killTweensOf(borderLine);
          gsap.to(borderLine, {
            scaleX: 0,
            duration: 0.3,
            ease: "power2.in",
          });
        }

        if (image) {
          gsap.to(image, {
            opacity: 0,
            scale: 0.8,
            duration: 0.2,
            ease: "power2.in",
          });
        }
      };

      card.addEventListener(
        "mouseenter",
        (e) => {
          handleEnter();

          if (image && !prefersReduced) {
            gsap.killTweensOf(image);
            gsap.set(image, { x: e.clientX, y: e.clientY });
            gsap.to(image, {
              opacity: 1,
              scale: 1,
              duration: 0.2,
              ease: "power2.out",
            });
          }
        },
        { signal },
      );

      card.addEventListener(
        "mousemove",
        (e) => {
          if (prefersReduced || !image) return;
          gsap.to(image, {
            x: e.clientX,
            y: e.clientY,
            duration: 0.1,
            ease: "none",
          });
        },
        { signal },
      );

      card.addEventListener("mouseleave", handleLeave, { signal });

      card.addEventListener("focusin", handleEnter, { signal });
      card.addEventListener("focusout", handleLeave, { signal });
    });
  });
</script>
