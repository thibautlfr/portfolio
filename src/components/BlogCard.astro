---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  draft?: boolean;
}

const { title, description, date, tags, slug, draft = false } = Astro.props;
---

<article class="py-6 first:pt-0 md:py-8">
  <div class="flex items-baseline gap-3">
    <h3 class="text-xl font-bold md:text-2xl">
      <a href={`/blog/${slug}`} class="hover:underline">{title}</a>
    </h3>
    {
      draft && (
        <span class="rounded-full border border-neutral-300 px-2 text-xs text-neutral-500">
          brouillon
        </span>
      )
    }
  </div>

  <p class="mt-2 max-w-prose text-base text-neutral-500">{description}</p>

  <div
    class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-neutral-500"
  >
    <span>{tags.join(", ")}</span>
    <span class="ml-auto"
      >{
        date.toLocaleDateString("fr-FR", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }</span
    >
  </div>
</article>
