---

<div class="menu-layer fixed inset-0 z-40 invisible bg-teal-400"></div>
<div class="menu-layer fixed inset-0 z-40 invisible bg-teal-600"></div>
<div
  class="menu-overlay fixed inset-0 z-50 invisible bg-teal-900 text-teal-50 px-8 py-18"
>
  <nav class="h-full flex">
    <ul
      class="menu-links flex flex-col gap-4 text-5xl font-heading font-extrabold"
    >
      <li class="overflow-hidden"><a class="block" href="/">HOME</a></li>
      <li class="overflow-hidden">
        <a class="block" href="/projects">PROJECTS</a>
      </li>
      <li class="overflow-hidden"><a class="block" href="/blog">BLOG</a></li>
      <li class="overflow-hidden"><a class="block" href="/about">ABOUT</a></li>
    </ul>
  </nav>
</div>

<button
  class="menu-button relative z-60 w-fit flex items-center gap-[0.3rem] cursor-pointer leading-none overflow-visible"
>
  <span class="relative inline-block whitespace-nowrap h-[1em] overflow-hidden">
    <span class="menu-text flex flex-col leading-none">
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
    </span>
  </span>
  <span class="mt-0.5 cross inline-flex items-center h-[1em]">+</span>
</button>

<script>
  import { gsap } from "gsap";

  const button = document.querySelector(".menu-button");
  const menuText = button?.querySelector(".menu-text");
  const cross = button?.querySelector(".cross");
  const overlay = document.querySelector(".menu-overlay");
  const layers = document.querySelectorAll(".menu-layer");
  const links = document.querySelectorAll(".menu-links a");

  if (!button || !menuText || !cross || !overlay)
    throw new Error("Menu elements not found");

  const spans = menuText.querySelectorAll("span");
  const total = spans.length;
  const mid = Math.floor(total / 2);
  const step = (1 / total) * 100;

  let isOpen = false;
  let isAnimating = false;

  gsap.set(overlay, { xPercent: 100 });
  gsap.set(layers, { xPercent: 100 });
  gsap.set(links, { yPercent: 100, rotate: 6 });

  button.addEventListener("click", () => {
    if (isAnimating) return;
    isAnimating = true;

    if (!isOpen) {
      gsap.set(overlay, { visibility: "visible" });
      gsap.set(layers, { visibility: "visible" });

      gsap.to(layers, {
        xPercent: 0,
        duration: 0.8,
        ease: "power4.inOut",
        stagger: 0.06,
      });

      gsap.to(button, {
        color: "#f0fdfa",
        duration: 0.8,
        ease: "power4.inOut",
      });
      gsap.to(overlay, {
        xPercent: 0,
        duration: 0.8,
        ease: "power4.inOut",
        delay: 0.12,
      });

      gsap.to(links, {
        yPercent: 0,
        rotate: 0,
        duration: 0.6,
        ease: "power3.out",
        stagger: 0.07,
        delay: 0.4,
      });

      gsap.to(menuText, {
        yPercent: -(mid * step),
        duration: 0.8,
        ease: "power3.out",
        onComplete: () => {
          isOpen = true;
          isAnimating = false;
        },
      });
    } else {
      gsap.to(button, {
        color: "#000000",
        duration: 0.8,
        ease: "power4.inOut",
      });

      gsap.to(overlay, {
        xPercent: 100,
        duration: 0.8,
        ease: "power4.inOut",
      });

      gsap.to([...layers].reverse(), {
        xPercent: 100,
        duration: 0.8,
        ease: "power4.inOut",
        stagger: 0.06,
        delay: 0.12,
        onComplete: () => {
          gsap.set(overlay, { visibility: "hidden" });
          gsap.set(layers, { visibility: "hidden" });
          gsap.set(links, { yPercent: 100, rotate: 6 });
          isOpen = false;
          isAnimating = false;
        },
      });

      gsap.to(menuText, {
        yPercent: -((total - 1) * step),
        duration: 0.8,
        ease: "power3.out",
        onComplete: () => gsap.set(menuText, { yPercent: 0 }),
      });
    }

    gsap.to(cross, {
      rotation: isOpen ? 0 : 405,
      duration: 0.8,
      ease: "power3.out",
    });
  });
</script>
