<!-- Invisible layers for opening effect-->
<div
  class="menu-layer fixed top-0 bottom-0 right-0 w-full xl:w-1/4 lg:w-[40%] z-40 invisible bg-teal-400"
>
</div>
<div
  class="menu-layer fixed top-0 bottom-0 right-0 w-full xl:w-1/4 lg:w-[40%] z-40 invisible bg-teal-600"
>
</div>

<div
  class="menu-overlay fixed top-0 bottom-0 right-0 w-full xl:w-1/4 lg:w-[40%] z-50 invisible bg-teal-900 text-teal-50 px-8 py-18"
>
  <nav class="h-fit flex bg">
    <!-- prettier-ignore -->
    <ul class="menu-links flex flex-col gap-4 text-5xl font-heading font-extrabold [&:hover>li]:opacity-50 [&>li]:transition-opacity [&>li]:duration-300 [&:hover>li:hover]:opacity-100">

      <li class="overflow-hidden">
        <a class="block" href="/">
          HOME<sup class="text-base font-sans align-super opacity-50 ml-1">1</sup>
        </a>
      </li>

      <li class="overflow-hidden">
        <a class="block" href="/projects">
          PROJECTS<sup class="text-base font-sans align-super opacity-50 ml-1">2</sup>
        </a>
      </li>

      <li class="overflow-hidden">
        <a class="block" href="/blog">
          BLOG<sup class="text-base font-sans align-super opacity-50 ml-1">3</sup>
        </a>
      </li>

      <li class="overflow-hidden">
        <a class="block" href="/about">
          ABOUT<sup class="text-base font-sans align-super opacity-50 ml-1">4</sup>
        </a>
      </li>

      <li class="overflow-hidden">
        <a class="block" href="/contact">
          CONTACT<sup class="text-base font-sans align-super opacity-50 ml-1">5</sup>
        </a>
      </li>
    </ul>
  </nav>
</div>

<button
  class="menu-button relative z-60 w-fit flex items-center gap-[0.3rem] cursor-pointer leading-none overflow-visible border px-2 py-1 rounded-full"
>
  <span class="relative inline-block whitespace-nowrap h-[1em] overflow-hidden">
    <span class="menu-text flex flex-col leading-none">
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
    </span>
  </span>
  <span class="mt-0.5 cross inline-flex items-center h-[1em]">+</span>
</button>

<script>
  import { gsap } from "gsap";

  const button = document.querySelector(".menu-button")!;
  const menuText = button.querySelector(".menu-text")!;
  const cross = button.querySelector(".cross")!;
  const overlay = document.querySelector(".menu-overlay")!;
  const layers = document.querySelectorAll(".menu-layer");
  const links = document.querySelectorAll(".menu-links a");

  const ANIM = {
    slideDuration: 0.8,
    linksDuration: 0.6,
    slideEase: "power4.inOut",
    contentEase: "power3.out",
    layerStagger: 0.06,
    linkStagger: 0.07,
    colorOpen: "#f0fdfa",
    colorClosed: "#000000",
    linkRotation: 6,
    crossRotation: 405,
    overlayOffset: 0.12,
    linksOffset: 0.4,
  };

  const total = menuText.querySelectorAll("span").length;
  const mid = Math.floor(total / 2);
  const step = (1 / total) * 100;

  let isOpen = false;
  let textTween: gsap.core.Tween | null = null;

  gsap.set(overlay, { xPercent: 100 });
  gsap.set(layers, { xPercent: 100 });
  gsap.set(links, { yPercent: 100, rotate: ANIM.linkRotation });

  const tl = gsap.timeline({
    paused: true,
    onStart: () => {
      gsap.set([overlay, ...layers], { visibility: "visible" });
    },
    onReverseComplete: () => {
      gsap.set([overlay, ...layers], { visibility: "hidden" });
      gsap.set(links, { yPercent: 100, rotate: ANIM.linkRotation });
    },
  });

  tl.to(
    layers,
    {
      xPercent: 0,
      duration: ANIM.slideDuration,
      ease: ANIM.slideEase,
      stagger: ANIM.layerStagger,
    },
    0,
  )
    .to(
      button,
      {
        color: ANIM.colorOpen,
        duration: ANIM.slideDuration,
        ease: ANIM.slideEase,
      },
      0,
    )
    .to(
      overlay,
      {
        xPercent: 0,
        duration: ANIM.slideDuration,
        ease: ANIM.slideEase,
      },
      ANIM.overlayOffset,
    );

  function animateTextOpen() {
    textTween = gsap.to(menuText, {
      yPercent: -(mid * step),
      duration: ANIM.slideDuration,
      ease: ANIM.contentEase,
    });
  }

  function animateTextClose() {
    textTween = gsap.to(menuText, {
      yPercent: -((total - 1) * step),
      duration: ANIM.slideDuration,
      ease: ANIM.contentEase,
      onComplete: () => gsap.set(menuText, { yPercent: 0 }),
    });
  }

  function animateLinks() {
    gsap.to(links, {
      yPercent: 0,
      rotate: 0,
      duration: ANIM.linksDuration,
      ease: ANIM.contentEase,
      stagger: ANIM.linkStagger,
      delay: ANIM.linksOffset,
    });
  }

  function animateCross() {
    gsap.to(cross, {
      rotation: isOpen ? 0 : ANIM.crossRotation,
      duration: ANIM.slideDuration,
      ease: ANIM.contentEase,
    });
  }

  button.addEventListener("click", () => {
    if (tl.isActive() || textTween?.isActive()) return;

    if (!isOpen) {
      tl.play(0);
      animateLinks();
      animateTextOpen();
    } else {
      tl.reverse();
      animateTextClose();
    }

    animateCross();
    isOpen = !isOpen;
  });
</script>
