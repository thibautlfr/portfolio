---
import { navLinks, socials } from "../config";
---

<!-- Invisible layers for opening effect-->
<div
  class="menu-layer invisible fixed top-0 right-0 bottom-0 z-40 w-full bg-teal-400 lg:w-[40%] xl:w-1/4"
>
</div>
<div
  class="menu-layer invisible fixed top-0 right-0 bottom-0 z-40 w-full bg-teal-600 lg:w-[40%] xl:w-1/4"
>
</div>

<div
  class="menu-overlay invisible fixed top-0 right-0 bottom-0 z-50 w-full bg-teal-900 px-8 pt-18 pb-8 text-teal-50 lg:w-[40%] xl:w-1/4"
>
  <nav id="main-nav" class="flex h-full flex-col justify-between">
    <!-- prettier-ignore -->
    <ul class="menu-links flex flex-col gap-4 text-5xl font-heading font-extrabold [&:hover>li]:opacity-50 [&>li]:transition-opacity [&>li]:duration-300 [&:hover>li:hover]:opacity-100">
      {navLinks.map((link, i) => (
        <li class="overflow-hidden">
          <a class="block" href={link.href}>
            {link.label}<sup class="text-base font-sans align-super text-teal-400 ml-1">{i + 1}</sup>
          </a>
        </li>
      ))}
    </ul>

    <div class="menu-socials">
      <p class="mb-3 font-sans text-sm tracking-widest text-teal-400 uppercase">
        Socials
      </p>
      <ul
        class="flex gap-6 font-sans text-base [&:hover>li]:opacity-50 [&:hover>li:hover]:opacity-100 [&>li]:transition-opacity [&>li]:duration-300"
      >
        {
          socials.map((s) => (
            <li class="overflow-hidden">
              <a
                class="social-link block"
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
              >
                {s.label}
                <span class="sr-only"> (opens in new tab)</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</div>

<button
  class="menu-button relative z-60 flex w-fit cursor-pointer items-center gap-[0.3rem] overflow-visible rounded-full border px-3 py-1.5 leading-none"
  aria-label="Menu"
>
  <span class="relative inline-block h-[1em] overflow-hidden whitespace-nowrap">
    <span class="menu-text flex flex-col leading-none">
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
      <span>close</span>
      <span>menu</span>
    </span>
  </span>
  <span class="cross mt-0.5 inline-flex h-[1em] items-center">+</span>
</button>

<script>
  import { gsap } from "gsap";

  document.addEventListener("astro:page-load", () => {
    const button = document.querySelector(".menu-button")!;
    const menuText = button.querySelector(".menu-text")!;
    const cross = button.querySelector(".cross")!;
    const overlay = document.querySelector(".menu-overlay")!;
    const layers = document.querySelectorAll(".menu-layer");
    const links = document.querySelectorAll(".menu-links a");
    const socials = document.querySelector(".menu-socials")!;
    const socialLinks = document.querySelectorAll(".social-link");

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    const ANIM = {
      slideDuration: 0.8,
      linksDuration: 0.6,
      slideEase: "power4.inOut",
      contentEase: "power3.out",
      layerStagger: 0.06,
      linkStagger: 0.07,
      colorOpen: "#f0fdfa",
      colorClosed: "#000000",
      linkRotation: 6,
      crossRotation: 405,
      overlayOffset: 0.12,
      linksOffset: 0.4,
    };

    const total = menuText.querySelectorAll("span").length;
    const mid = Math.floor(total / 2);
    const step = (1 / total) * 100;

    let isOpen = false;
    let textTween: gsap.core.Tween | null = null;

    gsap.set(overlay, { xPercent: 100 });
    gsap.set(layers, { xPercent: 100 });
    gsap.set(links, { yPercent: 100, rotate: ANIM.linkRotation });
    gsap.set(socials, { opacity: 0, yPercent: 20 });
    gsap.set(socialLinks, { yPercent: 100 });

    const tl = gsap.timeline({
      paused: true,
      onStart: () => {
        gsap.set([overlay, ...layers], { visibility: "visible" });
      },
      onReverseComplete: () => {
        gsap.set([overlay, ...layers], { visibility: "hidden" });
        gsap.set(links, { yPercent: 100, rotate: ANIM.linkRotation });
        gsap.set(socials, { opacity: 0, yPercent: 20 });
        gsap.set(socialLinks, { yPercent: 100 });
      },
    });

    tl.to(
      layers,
      {
        xPercent: 0,
        duration: ANIM.slideDuration,
        ease: ANIM.slideEase,
        stagger: ANIM.layerStagger,
      },
      0,
    )
      .to(
        button,
        {
          color: ANIM.colorOpen,
          duration: ANIM.slideDuration,
          ease: ANIM.slideEase,
        },
        0,
      )
      .to(
        overlay,
        {
          xPercent: 0,
          duration: ANIM.slideDuration,
          ease: ANIM.slideEase,
        },
        ANIM.overlayOffset,
      );

    function animateTextOpen() {
      textTween = gsap.to(menuText, {
        yPercent: -(mid * step),
        duration: ANIM.slideDuration,
        ease: ANIM.contentEase,
      });
    }

    function animateTextClose() {
      textTween = gsap.to(menuText, {
        yPercent: -((total - 1) * step),
        duration: ANIM.slideDuration,
        ease: ANIM.contentEase,
        onComplete: () => gsap.set(menuText, { yPercent: 0 }),
      });
    }

    function animateLinks() {
      gsap.to(links, {
        yPercent: 0,
        rotate: 0,
        duration: ANIM.linksDuration,
        ease: ANIM.contentEase,
        stagger: ANIM.linkStagger,
        delay: ANIM.linksOffset,
      });
      gsap.to(socials, {
        opacity: 1,
        yPercent: 0,
        duration: ANIM.linksDuration,
        ease: ANIM.contentEase,
        delay: ANIM.linksOffset + ANIM.linkStagger * links.length,
      });
      gsap.to(socialLinks, {
        yPercent: 0,
        duration: ANIM.linksDuration,
        ease: ANIM.contentEase,
        stagger: 0.05,
        delay: ANIM.linksOffset + ANIM.linkStagger * links.length,
      });
    }

    function animateCross() {
      gsap.to(cross, {
        rotation: isOpen ? 0 : ANIM.crossRotation,
        duration: ANIM.slideDuration,
        ease: ANIM.contentEase,
      });
    }

    button.addEventListener("click", () => {
      if (!prefersReduced && (tl.isActive() || textTween?.isActive())) return;

      if (!isOpen) {
        document.body.style.overflow = "hidden";
        if (prefersReduced) {
          gsap.set([overlay, ...layers], {
            visibility: "visible",
            xPercent: 0,
          });
          gsap.set(links, { yPercent: 0, rotate: 0 });
          gsap.set(socials, { opacity: 1, yPercent: 0 });
          gsap.set(socialLinks, { yPercent: 0 });
          gsap.set(button, { color: ANIM.colorOpen });
          gsap.set(cross, { rotation: ANIM.crossRotation });
          gsap.set(menuText, { yPercent: -(mid * step) });
        } else {
          tl.play(0);
          animateLinks();
          animateTextOpen();
        }
      } else {
        document.body.style.overflow = "";
        if (prefersReduced) {
          gsap.set([overlay, ...layers], {
            visibility: "hidden",
            xPercent: 100,
          });
          gsap.set(links, { yPercent: 100, rotate: ANIM.linkRotation });
          gsap.set(socials, { opacity: 0, yPercent: 20 });
          gsap.set(socialLinks, { yPercent: 100 });
          gsap.set(button, { color: ANIM.colorClosed });
          gsap.set(cross, { rotation: 0 });
          gsap.set(menuText, { yPercent: 0 });
        } else {
          tl.reverse();
          animateTextClose();
        }
      }

      if (!prefersReduced) animateCross();
      isOpen = !isOpen;
    });
  });
</script>
