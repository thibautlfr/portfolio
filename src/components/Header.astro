---
import IconCube from "@components/icons/IconCube.astro";
import Menu from "@components/Menu.astro";
import { getLocaleFromUrl, localizedHref } from "@i18n/utils";

interface Props {
  altLocaleUrl?: string | null;
}

const { altLocaleUrl } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const homeHref = localizedHref("/", locale);

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const segments = pathname.split("/").filter(Boolean);

// Skip the locale prefix ("en") when building the breadcrumb segment
const localePrefix = locale === "fr" ? null : locale;
const contentSegments = localePrefix
  ? segments.filter((s) => s !== localePrefix)
  : segments;
const slug = contentSegments[0] || null;
const slugHref = slug ? localizedHref(`/${slug}`, locale) : null;
---

<header
  class="sticky top-0 z-30 flex items-center justify-between border-b border-sage-6 bg-sage-1 px-6 py-6 select-none md:px-10 lg:px-16"
>
  <div class="flex items-center text-xl leading-none font-bold md:text-3xl">
    <IconCube class="size-5 md:size-7.5" />
    <a href={homeHref} class="hover:underline">thibautlfr</a>
    {
      slug && slugHref && (
        <a
          href={slugHref}
          class="text-teal-11 underline md:no-underline md:hover:underline"
        >
          /{slug}
        </a>
      )
    }
  </div>
  <Menu altLocaleUrl={altLocaleUrl} />
</header>
