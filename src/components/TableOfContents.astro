---
import { useTranslations } from "@i18n/utils";
import type { Locale } from "@i18n/utils";

interface Props {
  headings: { depth: number; slug: string; text: string }[];
  locale?: Locale;
}

const { headings, locale = "fr" } = Astro.props;
const toc = headings;
const t = useTranslations(locale);
---

{
  toc.length > 0 && (
    <aside class="order-1 mb-8 border-b pb-6 lg:order-last lg:mb-0 lg:shrink-0 lg:border-b-0 lg:border-l lg:pb-0 lg:pl-6">
      <nav aria-label={t("toc.aria")} class="lg:sticky lg:top-30">
        <h2 class="text-sm font-semibold tracking-wide uppercase">{t("toc.title")}</h2>
        <ol class="mt-3 space-y-1.5 text-sm">
          {toc.map((heading) => (
            <li class={heading.depth === 3 ? "pl-4" : ""}>
              <a
                href={`#${heading.slug}`}
                class="text-sage-11 transition-colors hover:md:hover:text-teal-11"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </aside>
  )
}
