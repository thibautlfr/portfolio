---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
  label?: string;
}

const { headings, label = "Table of contents" } = Astro.props;
const toc = headings;
---

{
  toc.length > 0 && (
    <aside class="order-1 mb-8 border-b pb-6 lg:order-last lg:mb-0 lg:shrink-0 lg:border-b-0 lg:border-l lg:pb-0 lg:pl-6">
      <nav aria-label={label} class="lg:sticky lg:top-30">
        <h2 class="text-sm font-semibold tracking-wide uppercase">{label}</h2>
        <ol class="mt-3 space-y-1.5 text-sm">
          {toc.map((heading) => (
            <li class={heading.depth === 3 ? "pl-4" : ""}>
              <a
                href={`#${heading.slug}`}
                class="text-sage-11 hover:md:hover:text-teal-11 transition-colors"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    </aside>
  )
}
