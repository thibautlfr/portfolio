---
interface Props {
  title: string;
  description: string;
  date: Date;
  status: "finished" | "wip";
  stack: string[];
  repository?: string;
  live?: string;
  slug: string;
}

const { title, description, date, status, stack, repository, live } =
  Astro.props;
---

<article class="py-6 first:pt-0 md:py-8">
  <div class="flex items-baseline gap-3">
    <h3 class="text-xl font-bold md:text-2xl">{title}</h3>
    {
      status === "wip" && (
        <span class="rounded-full border border-neutral-300 px-2 text-xs text-neutral-500">
          en cours
        </span>
      )
    }
  </div>

  <p class="mt-2 max-w-prose text-base text-neutral-500">{description}</p>

  <div
    class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-neutral-500"
  >
    <span>{stack.join(", ")}</span>
    <span class="ml-auto">{date.getFullYear()}</span>
  </div>

  {
    (repository || live) && (
      <div class="mt-3 flex gap-3 text-xs">
        {repository && (
          <a
            href={repository}
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral-500 underline hover:text-neutral-700"
          >
            repository
            <span class="sr-only"> (s'ouvre dans un nouvel onglet)</span>
          </a>
        )}
        {live && (
          <a
            href={live}
            target="_blank"
            rel="noopener noreferrer"
            class="text-neutral-500 underline hover:text-neutral-700"
          >
            demo<span class="sr-only"> (s'ouvre dans un nouvel onglet)</span>
          </a>
        )}
      </div>
    )
  }
</article>
