---
import Link from "@components/icons/Link.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { useTranslations } from "@i18n/utils";
import type { Locale } from "@i18n/utils";

interface Props {
  title: string;
  description: string;
  date: number;
  status: "finished" | "wip";
  stack: string[];
  slug: string;
  live?: string;
  repository?: string;
  cover?: ImageMetadata;
  locale?: Locale;
  isFallback?: boolean;
}

const {
  title,
  description,
  date,
  status,
  stack,
  slug,
  live,
  repository,
  cover,
  locale = "fr",
  isFallback = false,
} = Astro.props;

const t = useTranslations(locale);
---

<article class="flex flex-col gap-6 md:flex-row">
  <div class="flex flex-col md:min-w-2/4">
    <div class="mb-2 flex items-center gap-3">
      <h3
        class="group-hover:text-teal-11 text-xl font-bold transition-colors md:text-2xl"
      >
        {title}
      </h3>
      {
        status === "wip" && (
          <span class="border-sage-7 text-sage-11 rounded-full border px-2 text-xs">
            {t("project.wip")}
          </span>
        )
      }
      {
        isFallback && (
          <span class="border-sage-7 text-sage-11 rounded-full border px-2 text-xs">
            {t("content.frenchOnlyBadge")}
          </span>
        )
      }
    </div>
    <div class="flex h-full flex-col gap-3">
      <div>
        <p class="text-sage-11">{t("project.date")}</p>
        <p>{date}</p>
      </div>
      <div>
        <p class="text-sage-11">{t("project.description")}</p>
        <p class="max-w-[50ch]">{description}</p>
      </div>
      <div>
        <p class="text-sage-11">{t("project.stack")}</p>
        <div class="flex max-w-prose flex-wrap gap-2 text-xs">
          {
            stack.map((tech) => (
              <span class="border-sage-7 rounded-sm border px-2 py-1">
                {tech}
              </span>
            ))
          }
        </div>
      </div>
      {
        live && (
          <div class="md:mt-auto">
            <p class="text-sage-11">{t("project.demo")}</p>
            <a
              href={live}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-teal-9 inline-flex items-center gap-1 underline"
            >
              {live}
              <Link />
            </a>
            <br />
            {repository && (
              <a
                href={repository}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-teal-9 inline-flex items-center gap-1 underline"
              >
                {repository}
                <Link />
              </a>
            )}
          </div>
        )
      }
    </div>
  </div>
  {
    cover && (
      <a href={live} target="_blank" rel="noopener noreferrer">
        <Image
          src={cover}
          alt={`${t("project.coverAlt")} ${title}`}
          aria-hidden="true"
          class="border-sage-6 aspect-video h-full w-full rounded-md border object-cover"
          width={1200}
          densities={[1, 2]}
          quality={80}
        />
      </a>
    )
  }
</article>
