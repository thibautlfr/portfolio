---
interface Props {
  title: string;
  description: string;
  date: Date;
  status: "finished" | "wip";
  stack: string[];
  repository?: string;
  live?: string;
  slug: string;
}

const { title, description, date, status, stack, repository, live } =
  Astro.props;
---

<article class="py-6 md:py-8 first:pt-0">
  <div class="flex items-baseline gap-3">
    <h3 class="text-xl md:text-2xl font-bold">{title}</h3>
    {
      status === "wip" && (
        <span class="text-xs text-neutral-400 border border-neutral-300 rounded-full px-2">
          wip
        </span>
      )
    }
  </div>

  <p class="text-base text-neutral-500 mt-2 max-w-prose">{description}</p>

  <div
    class="mt-3 text-xs text-neutral-400 flex items-center gap-x-4 gap-y-1 flex-wrap"
  >
    <span>{stack.join(", ")}</span>
    <span class="ml-auto">{date.getFullYear()}</span>
  </div>

  {
    (repository || live) && (
      <div class="flex gap-3 mt-3 text-xs">
        {repository && (
          <a
            href={repository}
            target="_blank"
            rel="noopener noreferrer"
            class="underline text-neutral-500 hover:text-neutral-700"
          >
            repository
          </a>
        )}
        {live && (
          <a
            href={live}
            target="_blank"
            rel="noopener noreferrer"
            class="underline text-neutral-500 hover:text-neutral-700"
          >
            live
          </a>
        )}
      </div>
    )
  }
</article>
