---
import BaseLayout from "@layouts/BaseLayout.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { getCollection, render } from "astro:content";
import "../../styles/blog.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout pageTitle={`${post.data.title} — Thibaut LEFRANCOIS`}>
  <div class="mx-auto max-w-5xl">
    <h1 class="text-3xl font-bold md:text-4xl">{post.data.title}</h1>
    <div
      class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 border-b pb-6 text-sm text-neutral-500"
    >
      <div class="flex flex-wrap gap-2">
        {
          post.data.tags.map((tag: string) => (
            <span class="rounded-lg border px-3 py-1">{tag.toUpperCase()}</span>
          ))
        }
      </div>
      <span class="font-medium">
        {
          post.data.date.toLocaleDateString("fr-FR", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </span>
    </div>

    <div
      class="relative mt-6 flex flex-col md:mt-8 lg:flex-row lg:gap-10"
    >
      <div class="blog-content order-2 max-w-prose lg:order-1">
        <Content />
      </div>
      <TableOfContents headings={headings} />
    </div>
  </div>
</BaseLayout>
