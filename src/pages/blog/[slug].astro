---
import BaseLayout from "@layouts/BaseLayout.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { getCollection, render } from "astro:content";
import "../../styles/blog.css";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter(
    (post) => import.meta.env.DEV || !post.data.draft,
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout pageTitle={`${post.data.title} — Thibaut LEFRANCOIS`}>
  <div class="flex items-baseline gap-3">
    <h1 class="text-3xl font-bold md:text-4xl">{post.data.title}</h1>
    {
      post.data.draft && (
        <span class="border-sage-7 text-sage-11 rounded-full border px-2 text-xs">
          brouillon
        </span>
      )
    }
  </div>
  <div
    class="text-sage-11 mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 border-b pb-6 text-sm"
  >
    <div class="flex flex-wrap gap-2">
      {
        post.data.tags.map((tag: string) => (
          <span class="rounded-lg border px-3 py-1">{tag}</span>
        ))
      }
    </div>
    <span class="font-medium">
      {
        post.data.date.toLocaleDateString("fr-FR", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </span>
    {
      post.data.links.length > 0 && (
        <div class="flex flex-wrap gap-2 sm:ml-auto">
          {post.data.links.map((link: { label: string; url: string }) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-sage-2 text-sage-12 hover:bg-sage-4 inline-flex items-center gap-1 rounded-lg border px-3 py-1 text-sm font-medium transition-colors"
            >
              {link.label}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                focusable="false"
              >
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
              <span class="sr-only">(ouvre dans un nouvel onglet)</span>
            </a>
          ))}
        </div>
      )
    }
  </div>

  <div class="relative mt-6 flex flex-col md:mt-8 lg:flex-row lg:gap-10">
    <div class="blog-content order-2 max-w-prose lg:order-1">
      <Content />
    </div>
    <TableOfContents headings={headings} />
  </div>
</BaseLayout>
