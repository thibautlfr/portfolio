---
import BaseLayout from "@layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import "../../styles/blog.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  pageTitle={`${post.data.title} — Thibaut LEFRANCOIS`}
  title={post.data.title}
  srOnlyTitle={false}
>
  <div
    class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-neutral-500"
  >
    <div class="flex flex-wrap gap-2">
      {
        post.data.tags.map((tag: string) => (
          <span class="rounded-lg border px-3 py-1">{tag.toUpperCase()}</span>
        ))
      }
    </div>
    <span class="font-medium">
      {
        post.data.date.toLocaleDateString("fr-FR", {
          year: "numeric",
          month: "long",
          day: "numeric",
        })
      }
    </span>
  </div>

  <div class="blog-content mt-6 max-w-prose md:mt-8">
    <Content />
  </div>
</BaseLayout>
