---
import BaseLayout from "@layouts/BaseLayout.astro";
import BlogCard from "@components/BlogCard.astro";
import { getCollection } from "astro:content";
import { groupPostsBySlug } from "../../lib/blog";

const allPosts = (await getCollection("blog")).filter(
  (post) => import.meta.env.DEV || !post.data.draft,
);

const displayPosts = [...groupPostsBySlug(allPosts).entries()]
  .map(([postSlug, versions]) => {
    const primary = versions.en ?? versions.fr;
    return {
      postSlug,
      title: primary.data.title,
      description: primary.data.description,
      date: primary.data.date,
      tags: primary.data.tags,
      draft: primary.data.draft,
      langs: Object.keys(versions) as ("en" | "fr")[],
    };
  })
  .sort((a, b) => b.date.getTime() - a.date.getTime());
---

<BaseLayout pageTitle="Blog — Thibaut LEFRANCOIS" title="Blog">
  <div class="flex flex-col gap-6">
    {
      displayPosts.map((post) => (
        <BlogCard
          title={post.title}
          description={post.description}
          date={post.date}
          tags={post.tags}
          slug={post.postSlug}
          draft={post.draft}
          langs={post.langs}
        />
      ))
    }
  </div>
</BaseLayout>
