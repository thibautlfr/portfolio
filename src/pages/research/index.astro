---
import BaseLayout from "@layouts/BaseLayout.astro";
import ResearchCard from "@components/ResearchCard.astro";
import { getCollection } from "astro:content";

const research = (await getCollection("research")).sort(
  (a, b) => b.data.date - a.data.date,
);
---

<BaseLayout pageTitle="Research — Thibaut LEFRANCOIS" title="Research">
  <div class="flex flex-col divide-y">
    {
      research.map((r) => (
        <div class="py-6 first:pt-0 md:py-8">
          <ResearchCard
            title={r.data.title}
            description={r.data.description}
            date={r.data.date}
            tags={r.data.tags}
            demo={r.data.demo}
            repository={r.data.repository}
          />
        </div>
      ))
    }
  </div>
</BaseLayout>
