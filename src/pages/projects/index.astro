---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";

const covers = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/*/cover.webp",
  { eager: true },
);

const projects = (await getCollection("projects")).sort(
  (a, b) =>
    Number(b.data.featured ?? false) - Number(a.data.featured ?? false) ||
    b.data.date - a.data.date,
);
---

<BaseLayout
  pageTitle="Projects — Thibaut LEFRANCOIS"
  title="Projects"
  isCenteredContent={false}
>
  <div class="flex w-full flex-col divide-y">
    {
      projects.map((project) => (
        <div class="py-6 first:pt-0 md:py-8">
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            date={project.data.date}
            status={project.data.status}
            stack={project.data.stack}
            slug={project.id}
            live={project.data.live}
            repository={project.data.repository}
            cover={
              covers[`/src/assets/projects/${project.id}/cover.webp`]?.default
            }
          />
        </div>
      ))
    }
  </div>
</BaseLayout>
