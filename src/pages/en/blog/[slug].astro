---
import BaseLayout from "@layouts/BaseLayout.astro";
import TableOfContents from "@components/TableOfContents.astro";
import { getCollection, render } from "astro:content";
import "../../../styles/blog.css";
import Link from "@components/icons/Link.astro";
import { resolveForLocale, bareSlug, findTranslation } from "@i18n/content";
import { dateLocale, localizedHref, useTranslations } from "@i18n/utils";

const locale = "en" as const;
const t = useTranslations(locale);

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  // Generate a route for every unique slug, using EN if available, FR as fallback
  const resolved = resolveForLocale(allPosts, "en").filter(
    ({ entry }) => import.meta.env.DEV || !entry.data.draft,
  );
  return resolved.map(({ entry: post, isFallback }) => ({
    params: { slug: bareSlug(post.id) },
    props: { post, isFallback },
  }));
}

const { post, isFallback } = Astro.props;
const { Content, headings } = await render(post);

// Compute alternate URL (the FR canonical for this post)
const allPosts = await getCollection("blog");
const frEntry = findTranslation(allPosts, post, "fr") ?? post; // post itself if already FR
const altLocaleUrl = `/${bareSlug(frEntry.id).replace(/^fr\//, "")}` === "/"
  ? `/blog/${bareSlug(frEntry.id)}`
  : `/blog/${bareSlug(frEntry.id)}`;
---

<BaseLayout
  pageTitle={`${post.data.title} — Thibaut LEFRANCOIS`}
  altLocaleUrl={altLocaleUrl}
>
  {
    isFallback && (
      <div class="border-sage-6 bg-sage-2 text-sage-11 mb-6 rounded-lg border px-4 py-3 text-sm">
        {t("content.frenchOnly")}
      </div>
    )
  }
  <div class="flex items-baseline gap-3">
    <h1 class="text-3xl font-bold md:text-4xl">{post.data.title}</h1>
    {
      post.data.draft && (
        <span class="border-sage-7 text-sage-11 rounded-full border px-2 text-xs">
          {t("blog.draft")}
        </span>
      )
    }
  </div>
  <div
    class="text-sage-11 mt-3 flex flex-wrap items-center gap-x-4 gap-y-2 border-b pb-6 text-sm"
  >
    <div class="flex flex-wrap gap-2">
      {
        post.data.tags.map((tag: string) => (
          <span class="rounded-lg border px-3 py-1">{tag}</span>
        ))
      }
    </div>
    <span class="font-medium">
      {
        post.data.date.toLocaleDateString(
          isFallback ? "fr-FR" : dateLocale(locale),
          {
            year: "numeric",
            month: "long",
            day: "numeric",
          },
        )
      }
    </span>
    {
      post.data.links.length > 0 && (
        <div class="flex flex-wrap gap-2 sm:ml-auto">
          {post.data.links.map((link: { label: string; url: string }) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-sage-2 text-sage-12 hover:bg-sage-4 inline-flex items-center gap-1 rounded-lg border px-3 py-1 text-sm font-medium transition-colors"
            >
              {link.label}
              <Link />
            </a>
          ))}
        </div>
      )
    }
  </div>

  <div class="relative mt-6 flex flex-col md:mt-8 lg:flex-row lg:gap-10">
    <!--
      When content is a fallback (FR only), declare lang="fr" on the content
      wrapper so screen readers and search engines know the language.
    -->
    <div
      class="blog-content order-2 max-w-prose lg:order-1"
      lang={isFallback ? "fr" : undefined}
    >
      <Content />
    </div>
    <TableOfContents headings={headings} locale={isFallback ? "fr" : locale} />
  </div>
</BaseLayout>
