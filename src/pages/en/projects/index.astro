---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";
import type { ImageMetadata } from "astro";
import { resolveForLocale, bareSlug } from "@i18n/content";

const locale = "en" as const;

const covers = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/*/cover.webp",
  { eager: true },
);

const allProjects = await getCollection("projects");
const projects = resolveForLocale(allProjects, locale).sort(
  (a, b) =>
    Number(b.entry.data.featured ?? false) -
      Number(a.entry.data.featured ?? false) ||
    b.entry.data.date - a.entry.data.date,
);
---

<BaseLayout
  pageTitle="Projects — Thibaut LEFRANCOIS"
  title="Projects"
  altLocaleUrl="/projects"
>
  <div class="flex flex-col divide-y md:max-w-[60vw]">
    {
      projects.map(({ entry: project, isFallback }) => (
        <div class="py-6 first:pt-0 md:py-8">
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            date={project.data.date}
            status={project.data.status}
            stack={project.data.stack}
            slug={bareSlug(project.id)}
            live={project.data.live}
            repository={project.data.repository}
            cover={
              covers[`/src/assets/projects/${bareSlug(project.id)}/cover.webp`]
                ?.default
            }
            locale={locale}
            isFallback={isFallback}
          />
        </div>
      ))
    }
  </div>
</BaseLayout>
